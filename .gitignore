# Dependency directories
node_modules/

# Beta Build outputs
dist/

# OS metadata
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Local data (User-specific)
data/teams.json
data/logos/*
!data/logos/.gitkeep

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Design templates (PSD/large images)
templates/

# API Tests
tests/

# Code signing binaries (downloaded by scripts/setup-signing.ps1)
signing/*.exe
signing/*.dll
signing/*.lib

# Secrets — never commit real credentials (only the .env.example template is tracked)
.env
.env.*
!.env.example

# Claude Code / agent state
.claude/
