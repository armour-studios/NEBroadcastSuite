# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# These values are baked into the official build by Armour Studios.
# End users of the pre-built installer do NOT need to configure anything here —
# the credentials are already included in the distributed EXE.

# ── Bug Reports ───────────────────────────────────────────────────────────────
# Discord webhook that receives in-app bug reports.
BUG_REPORT_WEBHOOK=

# ── Twitch Integration ────────────────────────────────────────────────────────
# Armour Studios' registered Twitch application (dev.twitch.tv/console).
# End users authenticate with their own Twitch account through the app UI —
# these are the app credentials, not the end user's credentials.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Signing secret for Twitch EventSub webhook payloads (any random string, 10-100 chars).
TWITCH_WEBHOOK_SECRET=
EVENTSUB_WEBHOOK_SECRET=

# ── Code Signing (build machine only) ────────────────────────────────────────
# Microsoft Trusted Signing — only needed when running: npm run build
# Leave blank for local dev (signing is skipped automatically).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
